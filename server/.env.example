# OPMP 环境变量配置示例
# 复制此文件为 .env 并修改配置

# 服务配置
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# JWT配置 (生产环境请修改!)
JWT_SECRET=your-super-secret-key-change-me-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS配置
CORS_ORIGIN=http://localhost:8080

# 日志级别
LOG_LEVEL=info

# 系统路径
PROC_PATH=/proc
SYS_PATH=/sys
ETC_PATH=/etc
VAR_LOG_PATH=/var/log

# Docker配置
DOCKER_SOCKET=/var/run/docker.sock

# 监控配置
MONITOR_INTERVAL=3000
MONITOR_HISTORY_SIZE=3600

# 限流配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
