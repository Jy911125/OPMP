# Environment Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# JWT Configuration
JWT_SECRET=opmp-dev-secret-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Log
LOG_LEVEL=debug

# System Paths
PROC_PATH=/proc
SYS_PATH=/sys
ETC_PATH=/etc
VAR_LOG_PATH=/var/log

# Docker
DOCKER_SOCKET=/var/run/docker.sock

# Monitor
MONITOR_INTERVAL=3000
MONITOR_HISTORY_SIZE=3600

# Rate Limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
